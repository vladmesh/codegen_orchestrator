# Postgres
POSTGRES_DB=orchestrator
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# OpenAI / LLM
OPENAI_API_KEY=your_openai_key_here
OPEN_ROUTER_KEY=your_openrouter_key_here

# Internal API
API_BASE_URL=http://api:8000

# RAG
RAG_INGEST_SECRET=replace_with_shared_secret
RAG_SUMMARY_PROVIDER=openai
RAG_SUMMARY_MODEL=gpt-4o-mini
RAG_SUMMARY_TOKEN_THRESHOLD=1200

# Logging / Observability
# Set to "console" for colored dev output, "json" for production (Loki/Grafana)
LOG_FORMAT=json
# Grafana admin password (default: admin)
GRAFANA_ADMIN_PASSWORD=admin

# Admin panel authentication (basic auth on nginx)
ADMIN_USER=admin
ADMIN_PASSWORD=change_me_in_production

# ===========================
# Langfuse (LLM Tracing) — self-hosted v3
# ===========================
# Tracing client keys — used by langgraph/workers to send traces.
# Must match LANGFUSE_INIT_PROJECT_PUBLIC/SECRET_KEY below.
# Leave empty to disable LLM tracing (graceful no-op).
LANGFUSE_PUBLIC_KEY=lf-pk-orchestrator
LANGFUSE_SECRET_KEY=lf-sk-orchestrator
LANGFUSE_HOST=http://langfuse-web:3000

# ClickHouse credentials (used by Langfuse for trace analytics)
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=change_me_in_production

# Langfuse secrets
# Generate: openssl rand -hex 32
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=
LANGFUSE_ENCRYPTION_KEY=

# MinIO (S3-compatible storage for Langfuse — required for event/media uploads)
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change_me_in_production

# Langfuse init — auto-creates org, project, and API keys on first boot.
# All values must be set (partial = Langfuse crashes with ZodError).
LANGFUSE_INIT_ORG_ID=codegen
LANGFUSE_INIT_ORG_NAME=codegen
LANGFUSE_INIT_PROJECT_ID=orchestrator
LANGFUSE_INIT_PROJECT_NAME=orchestrator
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=lf-pk-orchestrator
LANGFUSE_INIT_PROJECT_SECRET_KEY=lf-sk-orchestrator
LANGFUSE_INIT_USER_EMAIL=admin@codegen.local
LANGFUSE_INIT_USER_NAME=admin
LANGFUSE_INIT_USER_PASSWORD=changeme

# Secrets encryption (Fernet) — encrypts project secrets at rest in PostgreSQL
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRETS_ENCRYPTION_KEY=

# Secrets encryption (SOPS)
SOPS_AGE_KEY_FILE=/root/.age/key.txt

# Server Management
GHOST_SERVERS=109.235.70.139,80.209.235.229
# ===========================
# GitHub App Configuration
# ===========================
GITHUB_APP_ID=your_app_id
GITHUB_APP_PRIVATE_KEY_PATH=/app/keys/github_app.pem
GITHUB_APP_INSTALLATION_ID=your_installation_id
GITHUB_ORG=your_github_org

# ===========================
# Provisioning Configuration
# ===========================
PROVISIONING_TIMEOUT=600
PROVISIONING_MAX_RETRIES=3
PASSWORD_RESET_TIMEOUT=300
PASSWORD_RESET_POLL_INTERVAL=5

# SSH Configuration (for Ansible provisioning)
ORCHESTRATOR_SSH_PUBLIC_KEY="ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIDmhy0xxkHp+F4PcNzMl6yQX8tDHj8BeFrFpRINS9/4G"
ORCHESTRATOR_SSH_PRIVATE_KEY_PATH="/root/.ssh/id_ed25519"
# Public IP of the orchestrator host — used for UFW rules on managed servers
# to restrict monitoring ports (node_exporter, cadvisor) access
ORCHESTRATOR_PUBLIC_IP=

# Health Checking
# ===========================
HEALTH_CHECK_INTERVAL=60              # Check every 60 seconds
SSH_TIMEOUT=10                        # SSH connection timeout

# ===========================
# Notifications
# ===========================
NOTIFICATION_RATE_LIMIT=10            # Max notifications per user per hour

# Time4VPS (for server sync)
TIME4VPS_LOGIN=your_email@example.com
TIME4VPS_PASSWORD=your_password_here

# Factory.ai (for coding agents)
FACTORY_API_KEY=fk-your-api-key-here

# ===========================
# PO ReactAgent LLM (OpenRouter)
# ===========================
# All three are required. Without them the langgraph service starts but logs
# po_consumer_disabled and never reads po:input, so user messages get no reply.
PO_LLM_MODEL=anthropic/claude-sonnet-4-5
PO_LLM_BASE_URL=https://openrouter.ai/api/v1
PO_LLM_API_KEY=your_openrouter_key_here

# ===========================
# Architect ReactAgent LLM (OpenRouter)
# ===========================
# All three are required. Without them the architect service refuses to start
# with architect_llm_not_configured, and stories pile up in architect:queue
# undecomposed.
ARCHITECT_LLM_MODEL=anthropic/claude-sonnet-4-5
ARCHITECT_LLM_BASE_URL=https://openrouter.ai/api/v1
ARCHITECT_LLM_API_KEY=your_openrouter_key_here

# PO Summarization
SUMMARIZATION_MODEL=anthropic/claude-haiku-4-5
SUMMARIZATION_MAX_TOKENS=20000
SUMMARIZATION_TRIGGER_TOKENS=70000
SUMMARIZATION_MAX_SUMMARY_TOKENS=2000

# ===========================
# Self-hosted Docker Registry + Caddy TLS
# ===========================
# Single hostname for registry and HTTPS webhook endpoint
# This is the ONLY place the domain is configured
ORCHESTRATOR_HOSTNAME=your-hostname.example.com

# Registry basic auth credentials (shared across all projects for MVP)
REGISTRY_USER=registry
REGISTRY_PASSWORD=change_me_in_production
# Bcrypt hash for Caddy basic_auth — dollar signs MUST be escaped as $$ in .env
# Generate: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your_password'
REGISTRY_PASSWORD_HASH=$$2a$$14$$replace_with_actual_hash

# Loki push credentials (used by Promtail on prod servers to ship logs)
LOKI_PUSH_USER=loki
LOKI_PUSH_PASSWORD=change_me_in_production
# Bcrypt hash for Caddy basic_auth — same escaping rules as REGISTRY_PASSWORD_HASH
# Generate: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your_password'
LOKI_PUSH_PASSWORD_HASH=$$2a$$14$$replace_with_actual_hash

# ----- Worker agent runtime -----
# Pin the compose project name so live tests and the running stack agree on which
# containers to target, regardless of the checkout directory name.
COMPOSE_PROJECT_NAME=codegen_orchestrator
# Host path to a Claude Code session dir mounted into spawned worker containers.
# Use an ISOLATED COPY of ~/.claude, not your live session — workers get rw access.
#   mkdir -p ~/.claude-worker && cp ~/.claude/.credentials.json ~/.claude-worker/
# HOST_CLAUDE_DIR=/home/youruser/.claude-worker
# Host path to a dedicated Codex profile. Do not use ~/.codex: Codex workers
# need read-write access so the CLI can refresh ChatGPT subscription tokens.
# One-time setup (run on the Docker host):
#   install -d -m 0700 ~/.codex-worker
#   printf 'cli_auth_credentials_store = "file"\n' > ~/.codex-worker/config.toml
#   chmod 0600 ~/.codex-worker/config.toml
#   CODEX_HOME=~/.codex-worker codex login --device-auth
#   chmod 0600 ~/.codex-worker/auth.json
# HOST_CODEX_HOME=/home/youruser/.codex-worker
# Per-agent-process timeout inside the worker (seconds). Code default is 900,
# which fits live LLM engineering; override here only to tune.
# WORKER_SUBPROCESS_TIMEOUT_SECONDS=900
