# Postgres
POSTGRES_DB=orchestrator
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# OpenAI / LLM
OPENAI_API_KEY=your_openai_key_here
OPEN_ROUTER_KEY=your_openrouter_key_here

# Internal API
API_BASE_URL=http://api:8000

# RAG
RAG_INGEST_SECRET=replace_with_shared_secret
RAG_SUMMARY_PROVIDER=openai
RAG_SUMMARY_MODEL=gpt-4o-mini
RAG_SUMMARY_TOKEN_THRESHOLD=1200

# Logging / Observability
# Set to "console" for colored dev output, "json" for production (Loki/Grafana)
LOG_FORMAT=json
# Grafana admin password (default: admin)
GRAFANA_ADMIN_PASSWORD=admin

# Admin panel authentication (basic auth on nginx)
ADMIN_USER=admin
ADMIN_PASSWORD=change_me_in_production

# LangSmith (optional, for tracing)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=

# Secrets encryption (Fernet) — encrypts project secrets at rest in PostgreSQL
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRETS_ENCRYPTION_KEY=

# GitHub Webhook — verifies HMAC-SHA256 signatures from GitHub App webhooks
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
GITHUB_WEBHOOK_SECRET=

# Secrets encryption (SOPS)
SOPS_AGE_KEY_FILE=/root/.age/key.txt

# Server Management
GHOST_SERVERS=109.235.70.139,80.209.235.229
# ===========================
# GitHub App Configuration
# ===========================
GITHUB_APP_ID=your_app_id
GITHUB_APP_PRIVATE_KEY_PATH=/app/secrets/github_app_key.pem
GITHUB_APP_INSTALLATION_ID=your_installation_id
GITHUB_ORG=your_github_org

# ===========================
# Provisioning Configuration
# ===========================
PROVISIONING_TIMEOUT=600
PROVISIONING_MAX_RETRIES=3
PASSWORD_RESET_TIMEOUT=300
PASSWORD_RESET_POLL_INTERVAL=5

# SSH Configuration (for Ansible provisioning)
ORCHESTRATOR_SSH_PUBLIC_KEY="ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIDmhy0xxkHp+F4PcNzMl6yQX8tDHj8BeFrFpRINS9/4G"
ORCHESTRATOR_SSH_PRIVATE_KEY_PATH="/root/.ssh/id_ed25519"

# Health Checking
# ===========================
HEALTH_CHECK_INTERVAL=60              # Check every 60 seconds
SSH_TIMEOUT=10                        # SSH connection timeout

# ===========================
# Notifications
# ===========================
NOTIFICATION_RATE_LIMIT=10            # Max notifications per user per hour

# Time4VPS (for server sync)
TIME4VPS_LOGIN=your_email@example.com
TIME4VPS_PASSWORD=your_password_here

# Factory.ai (for coding agents)
FACTORY_API_KEY=fk-your-api-key-here

# ===========================
# PO ReactAgent LLM (OpenRouter)
# ===========================
PO_LLM_MODEL=anthropic/claude-sonnet-4-5
PO_LLM_BASE_URL=https://openrouter.ai/api/v1
PO_LLM_API_KEY=your_openrouter_key_here

# PO Summarization
SUMMARIZATION_MODEL=anthropic/claude-haiku-4-5
SUMMARIZATION_MAX_TOKENS=20000
SUMMARIZATION_TRIGGER_TOKENS=70000
SUMMARIZATION_MAX_SUMMARY_TOKENS=2000

# ===========================
# Self-hosted Docker Registry + Caddy TLS
# ===========================
# Single hostname for registry and HTTPS webhook endpoint
# This is the ONLY place the domain is configured
ORCHESTRATOR_HOSTNAME=your-hostname.example.com

# Registry basic auth credentials (shared across all projects for MVP)
REGISTRY_USER=registry
REGISTRY_PASSWORD=change_me_in_production
# Bcrypt hash for Caddy basic_auth — dollar signs MUST be escaped as $$ in .env
# Generate: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your_password'
REGISTRY_PASSWORD_HASH=$$2a$$14$$replace_with_actual_hash
