#!/bin/bash
# Pre-commit hook: Auto-format code using uv + ruff
# This hook runs automatically before each commit and FIXES formatting issues

set -euo pipefail

echo "🎨 Auto-formatting code before commit..."

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Get the root of the git repository
REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

# Check if uv is available
if ! command -v uv &> /dev/null; then
    echo -e "${RED}❌ uv not found. Install it: https://docs.astral.sh/uv/getting-started/installation/${NC}"
    exit 1
fi

# Get list of staged Python files (NUL-delimited to preserve spaces)
mapfile -d '' -t STAGED_FILES < <(git diff --cached --name-only --diff-filter=ACM -z -- '*.py')

if [ "${#STAGED_FILES[@]}" -eq 0 ]; then
    echo -e "${GREEN}✅ No Python files to format${NC}"
    exit 0
fi

echo -e "${YELLOW}📝 Formatting staged Python files...${NC}"

# Run ruff format + check --fix directly (avoids Make quoting issues)
if ! (uv run ruff format "${STAGED_FILES[@]}" && uv run ruff check --fix "${STAGED_FILES[@]}"); then
    echo -e "${RED}❌ Formatting failed. Aborting commit.${NC}"
    exit 1
fi

# Add the formatted files back to the commit
for file in "${STAGED_FILES[@]}"; do
    git add "$file"
done

echo -e "${GREEN}✅ Code formatted and added to commit${NC}"
exit 0
