#!/bin/bash
# Pre-push hook: Run linters and tests before pushing
# This hook runs automatically before each push and BLOCKS if checks fail

set -e

echo "🚀 Running pre-push validation..."

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Get the root of the git repository
REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

# Check if uv is available
if ! command -v uv &> /dev/null; then
    echo -e "${RED}❌ uv not found. Install it: https://docs.astral.sh/uv/getting-started/installation/${NC}"
    exit 1
fi

# Run linting checks
echo "🔎 Running linters..."
if ! make lint; then
    echo -e "${RED}❌ Linting failed!${NC}"
    echo -e "${YELLOW}💡 Fix linting errors before pushing${NC}"
    exit 1
fi

# Run unit tests locally (fast, no Docker)
echo "🧪 Running unit tests..."
if ! make test-unit; then
    echo -e "${RED}❌ Unit tests failed!${NC}"
    echo -e "${YELLOW}💡 Fix failing tests before pushing${NC}"
    exit 1
fi

echo -e "${GREEN}✅ All pre-push checks passed!${NC}"
exit 0
