{
    log {
        format json
    }
}

{$ORCHESTRATOR_HOSTNAME} {
    handle /v2/* {
        basic_auth {
            {$REGISTRY_USER} {$REGISTRY_PASSWORD_HASH}
        }
        reverse_proxy registry:5000
    }

    handle /loki/* {
        basic_auth {
            {$LOKI_PUSH_USER} {$LOKI_PUSH_PASSWORD_HASH}
        }
        uri strip_prefix /loki
        reverse_proxy loki:3100
    }

}
