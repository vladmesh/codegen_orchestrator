# syntax=docker/dockerfile:1.4
# Multi-stage Dockerfile optimized for testing with caching

FROM python:3.12-slim AS base

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    openssh-client \
    && rm -rf /var/lib/apt/lists/*

# === Test Dependencies Stage ===
FROM base AS test-deps

# Copy lock files first (for caching) — same pins as prod + pinned test toolchain
COPY services/scheduler/requirements.lock requirements-test.lock ./

# Install pinned runtime (matches prod) + pinned test toolchain
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install -r requirements.lock -r requirements-test.lock

# === Test Stage ===
FROM test-deps AS test

# Copy shared module
COPY shared /app/shared

# Copy source code
COPY services/scheduler/src ./src
COPY services/scheduler/tests ./tests
COPY services/scheduler/pytest.ini ./

# Run unit tests only (service tests need full environment via docker/test/service/scheduler.yml)
CMD ["pytest", "tests/unit/", "-v"]
