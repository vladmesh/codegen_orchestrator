# syntax=docker/dockerfile:1.4
# Multi-stage Dockerfile optimized for testing with caching

FROM python:3.12-slim AS base

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    && rm -rf /var/lib/apt/lists/*

# === Test Dependencies Stage ===
FROM base AS test-deps

# Copy only dependency files first (for caching)
COPY services/api/pyproject.toml ./

# Install runtime + test dependencies
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install . && \
    pip install pytest pytest-asyncio pytest-cov httpx respx rich typer "fakeredis>=2.34.1" makefun

# === Test Stage ===
FROM test-deps AS test

# Copy shared module
COPY shared /app/shared

# Copy source code
COPY services/api/src ./src
COPY services/api/tests ./tests
COPY services/api/pytest.ini ./

# Run tests
CMD ["pytest", "-v"]
