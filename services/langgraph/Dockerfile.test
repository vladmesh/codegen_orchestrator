# syntax=docker/dockerfile:1.4
# Multi-stage Dockerfile optimized for testing with caching

FROM python:3.12-slim AS base

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    openssh-client \
    && rm -rf /var/lib/apt/lists/*

# === Test Dependencies Stage ===
FROM base AS test-deps

# Copy lock files first (for caching) — same pins as prod + pinned test toolchain
COPY services/langgraph/requirements.lock requirements-test.lock ./

# Install pinned runtime (matches prod) + pinned test toolchain
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install -r requirements.lock -r requirements-test.lock

# === Test Stage ===
FROM test-deps AS test

# Copy shared module and install it as a package WITHOUT touching the pinned deps
# (shared's runtime deps are already covered by requirements.lock)
COPY shared /app/shared
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install --no-deps ./shared

# Copy source code
COPY services/langgraph/src ./src
COPY services/langgraph/tests ./tests
COPY services/langgraph/pytest.ini ./

# Run tests
CMD ["pytest", "-v"]
