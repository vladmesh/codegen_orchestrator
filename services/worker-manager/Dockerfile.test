# syntax=docker/dockerfile:1.4
# Multi-stage Dockerfile optimized for testing with caching

FROM python:3.12-slim AS base

WORKDIR /app
ENV PYTHONPATH=/app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# === Test Dependencies Stage ===
FROM base AS test-deps

# Copy only dependency files first (for caching)
COPY services/worker-manager/pyproject.toml ./

# Install service + test dependencies (shared is installed later in test stage)
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install . && \
    pip install pytest pytest-asyncio pytest-cov httpx docker fakeredis

# === Test Stage ===
FROM test-deps AS test

# Copy and install shared module (changes more often than deps)
COPY shared /app/shared
RUN --mount=type=cache,target=/root/.cache/pip \
    pip install ./shared

# Copy source code
COPY services/worker-manager/src ./src
COPY services/worker-manager/tests ./tests

# Run tests
CMD ["pytest", "-v"]
