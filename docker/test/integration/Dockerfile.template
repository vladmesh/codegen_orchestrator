FROM python:3.12-slim

WORKDIR /app

# Install git (required by copier) and curl
RUN apt-get update && apt-get install -y --no-install-recommends \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install pinned test toolchain (derived from uv.lock — includes pytest + copier + pyyaml)
COPY requirements-test.lock .
RUN pip install --no-cache-dir -r requirements-test.lock

# Copy tests (usually mounted, but good for caching)
COPY tests/integration/template /app/tests/integration/template

ENV PYTHONPATH=/app

CMD ["pytest"]
